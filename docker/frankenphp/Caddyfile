{
    auto_https off
    admin off
}

http://:8080 {
    root * /app/public

    mercure {
        publisher_jwt {$MERCURE_JWT_SECRET}
        subscriber_jwt {$MERCURE_JWT_SECRET}
        anonymous
        transport local
        cors_origins {$APP_ORIGIN} tauri://localhost
    }

    # Classic mode by default (matches the desktop build, see build/Caddyfile.desktop).
    # Opt into worker mode with:  php_server { worker /app/public/index.php }
    php_server
}
