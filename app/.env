# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables always win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILE.
# https://symfony.com/doc/current/configuration/secrets.html

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me-in-real-projects
###< symfony/framework-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=async
###< symfony/messenger ###

###> symfony/mercure-bundle ###
# Mercure hub served locally by FrankenPHP/Caddy (see docker/frankenphp/Caddyfile).
# URL used by the PHP app (symfony/mercure-bundle) to publish updates.
MERCURE_URL=http://127.0.0.1:8080/.well-known/mercure
# Public hub URL exposed to the browser.
MERCURE_PUBLIC_URL=http://127.0.0.1:8080/.well-known/mercure
# Single shared secret: symfony/mercure-bundle signs publisher JWTs with it,
# and the Caddy `mercure` directive validates both publisher and subscriber
# JWTs against the same value (see docker/frankenphp/Caddyfile).
# In a packaged desktop build this is generated at launch by the Tauri launcher
# and never persisted (loopback-internal, ephemeral hub).
MERCURE_JWT_SECRET=poc-dev-mercure-secret-0123456789abcdef
###< symfony/mercure-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Local SQLite database. In a packaged desktop build the launcher overrides this
# with an app-data path (see desktop/src-tauri/src/main.rs). SQLite needs no
# serverVersion. Dev/Docker overrides it to an absolute path via compose.yaml.
DATABASE_URL=sqlite:///%kernel.project_dir%/var/data/app.db
###< doctrine/doctrine-bundle ###
