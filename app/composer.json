{
  "name": "local/{{ project-name }}-symfony-app",
  "description": "Symfony 8.1 app served by FrankenPHP, packaged with Tauri ({{ product_name }}).",
  "type": "project",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "ext-pdo_sqlite": "*",
    "doctrine/dbal": "^4.0",
    "doctrine/doctrine-bundle": "^3.2",
    "doctrine/doctrine-migrations-bundle": "^4.0",
    "doctrine/orm": "^3.6",
    "doctrine/persistence": "^4.0",
    "symfony/asset": "8.1.*",
    "symfony/console": "8.1.*",
    "symfony/doctrine-messenger": "8.1.*",
    "symfony/dotenv": "8.1.*",
    "symfony/flex": "^2",
    "symfony/framework-bundle": "8.1.*",
    "symfony/mercure-bundle": "^0.4.2",
    "symfony/messenger": "8.1.*",
    "symfony/runtime": "8.1.*",
    "symfony/translation": "8.1.*",
    "symfony/twig-bundle": "8.1.*",
    "symfony/uid": "8.1.*",
    "symfony/webpack-encore-bundle": "^2.2",
    "symfony/yaml": "8.1.*",
    "twig/extra-bundle": "^3.12",
    "twig/twig": "^3.12"
  },
  "require-dev": {
    "symfony/debug-bundle": "8.1.*",
    "symfony/maker-bundle": "^1.61",
    "symfony/var-dumper": "8.1.*",
    "symfony/web-profiler-bundle": "8.1.*"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "bump-after-update": true,
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "8.1.*"
    }
  }
}
